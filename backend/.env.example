PORT=3000

# Autenticação (obrigatória — o servidor não inicia sem isso)
# Gere uma string longa e aleatória, ex: openssl rand -hex 64
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=1d

# Redis (usado pela fila BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenAI (Whisper) — necessária no processo do worker
OPENAI_API_KEY=sk-coloque-sua-chave-aqui
